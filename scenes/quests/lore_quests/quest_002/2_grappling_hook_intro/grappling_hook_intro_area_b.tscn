[sub_resource type="GDScript" id="GDScript_m0rpm"]
script/source = "extends Node2D


func _ready() -> void:
	var player: Player = get_tree().get_first_node_in_group(\"player\")
	player.get_node(\"%PlayerHook\").debug_hit_from_inside = true
"

[sub_resource type="GDScript" id="GDScript_bdflk"]
script/source = "extends Node2D

@onready var door: Node2D = %Door

var _amount_remaining: int

func _ready() -> void:
	_amount_remaining = 0
	for c in get_children():
		if \"hook_control\" in c:
			_amount_remaining += 1
		else:
			c.process_mode = Node.PROCESS_MODE_DISABLED
			c.visible = false


func _award() -> void:
	for c in get_children():
		# TODO: identify the buttons differently.
		if not \"hook_control\" in c:
			c.process_mode = Node.PROCESS_MODE_INHERIT
			c.visible = true
	# TODO: more elegant way to cancel the current grappling hook.
	var player: Player = get_tree().get_first_node_in_group(\"player\")
	player.get_node(\"%PlayerHook\").remove_string()
	door.opened = true


func hit_target(_target: HookableArea) -> void:
	var amount_hooked: int = 0
	for c in get_children():
		if not \"hook_control\" in c:
			continue
		if not c.hook_control:
			continue
		if (c.hook_control as HookControl).hooked_to:
			amount_hooked += 1
	if amount_hooked >= _amount_remaining:
		_award()
"

