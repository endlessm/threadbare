[resource]
script = ExtResource("1_o7w2g")
title = "legends_without_name"
description = "Legend Without Name is an action-adventure game developed by the Knights Trinity team. The story follows a brave knight who ventures into a castle overrun by dark magic to defeat a powerful, terrifying wizard and restore peace to his kingdom. Driven by a noble purpose and aided by the cunning narrator, the protagonist sets out on his quest. Along the way, he must face not only the castle guards but also an illusion that drags him into a sunken laboratory; there, he must complete an ancient ritual to strip the wizard of his powers and ultimately defeat him."
authors = Array[String](["Eduardo G. Albertis Hidalgo", "Luis E. Rojas Inga", "Jade B. Hinostroza Pariona", "Dafne P. Incio Puyen", "Laura A. Gomez Linares", "Joaquin Pomayay"])
first_scene = "uid://b4t8ytuk1une7"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
