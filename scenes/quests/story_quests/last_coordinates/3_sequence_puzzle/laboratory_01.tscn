[sub_resource type="GDScript" id="GDScript_sdk78"]
script/source = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
@tool
class_name LevelGameLogic
extends Node
@onready var canvasModulate: CanvasModulate = get_node(\"/root/Laboratory01/CanvasModulate\")
@onready var allEnemies: Node2D = get_node(\"/root/Laboratory01/UnderGround/EnemyGuards\")

func _ready() -> void:  # Cambiar color a rojo
	if Engine.is_editor_hint():
		return
	for guard: Guard in get_tree().get_nodes_in_group(&\"guard_enemy\"):
		guard.player_detected.connect(self._on_player_detected)


func _on_player_detected(player: Node2D) -> void:
	if player.has_method(\"defeat\"):
		player.defeat()
	else:
		push_warning(\"Detected node does not have defeat() method\", player)

func _on_lightTurnOn() -> void:
	var tween: Tween = create_tween()
	tween.tween_property(canvasModulate, \"color\", Color(\"d3d3d3ff\"), 2.5)  # Cambiar color a rojo
	allEnemies.queue_free()
	print(\"Se hizo la luz\")
"

