[resource]
script = ExtResource("1_o4mt3")
title = "El Abandonado"
description = "Brennan es un aventurero humano maldito por la soledad y la falta de magia. Tras la masacre de su banda de mercenarios, vaga buscando hongos mágicos para obtener maná temporal a cambio de deteriorar su mente."
authors = Array[String](["Irma Galdos Montenegro", "Stephanie Ferrada Rodriguez", "Stefany Avalos Bejarano", "Ricardo Esteban Torres Lujan"])
