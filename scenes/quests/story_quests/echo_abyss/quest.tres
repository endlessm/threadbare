[ext_resource type="SpriteFrames" uid="uid://b6pm0p3stv78r" path="res://scenes/quests/story_quests/echo_abyss/player_components/first_form_azrael.tres" id="2_eghok"]

[resource]
script = ExtResource("1_poxji")
title = "Echo Abyss"
description = "“Echo Abyss” trata sobre un ser aparentemente humano que despierta en el fondo de un abismo sin recuerdos, sin pertenencias y sin saber por qué fue llevado allí. Rodeado por oscuridad y criaturas contaminadas, su único objetivo parece ser escapar. Para ascender debe atravesar distintos niveles del abismo enfrentándose a guardianes que impiden su avance. A medida que recupera fuerzas y absorbe la esencia de las criaturas del lugar, también recupera habilidades y fragmentos de memoria. Conforme avanza, se revela que estos guardianes no son enemigos cualquiera, sino partes desprendidas de su propio poder maligno. Lo que comenzó como un intento de supervivencia se transforma en el descubrimiento de una verdad inquietante: el protagonista no cayó por accidente, sino que fue encerrado en lo más profundo del abismo por la humanidad para contener una amenaza capaz de destruir el mundo. El ascenso no solo representa una salida física, sino también el regreso de aquello que alguna vez fue sellado."
authors = Array[String](["Edwin Cruz", "Tony Olaechea", "Nicole Nuñez", "Jhair Gonzales"])
first_scene = "uid://d17e77fj3d8bv"
sprite_frames = ExtResource("2_eghok")
animation_name = &"idle"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
