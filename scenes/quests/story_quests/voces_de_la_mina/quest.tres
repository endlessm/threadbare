[resource]
script = ExtResource("1_n7sx8")
title = "Voces de la mina."
description = "Juego de terror y exploración inspirado en Clock Tower, ambientado en una mina abandonada de Huancavelica, Perú. La protagonista es Elena Vargas, una joven ingeniera de minas escéptica que recibe un mensaje enigmático de su padre Carlos, un supervisor minero desaparecido hace 15 años en un derrumbe. El mensaje dice: \"Ven a buscarme. La mina tiene respuestas.\" Atraída por la esperanza, regresa al pueblo minero abandonado para descubrir la verdad."
authors = Array[String](["Aquino Hidalgo Ed Albert", "Cajas Monago Daniel", "Patiño Hellen", "Vera Maria", "León Díaz Jhosep"])
first_scene = "uid://bi4l076twin85"
sprite_frames = ExtResource("2_37pu6")
animation_name = &"portada"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
