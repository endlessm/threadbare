[ext_resource type="SpriteFrames" uid="uid://u4w7tgkf7ck7" path="res://scenes/quests/story_quests/equipo_1/1_stealth/stealth_components/equipo_1_guard_enemy.tres" id="2_x1u5d"]

[resource]
script = ExtResource("1_efdr1")
title = "La odisea del tiempo"
description = "Un viaje a través del tiempo para sanar el alma. Acompaña a Balder, un joven guerrero marcado por una antigua maldición que ha fragmentado su alma en tres versiones de sí mismo, cada una atrapada en una era distinta del tiempo. Para salvar el reino de Aetheris y evitar que \"La Ruptura\" consuma el mundo, deberás viajar al Pasado, el Presente y el Futuro. En esta aventura, el conflicto no se resuelve destruyendo a esas versiones, sino integrándose y reconciliándose con sus propios demonios internos: el niño que huyó lleno de culpa, el guerrero consumido por la ira, y el rey tirano en que podría convertirse."
first_scene = "uid://bxcfrq04dg30q"
sprite_frames = ExtResource("2_x1u5d")
animation_name = &"alerted"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
