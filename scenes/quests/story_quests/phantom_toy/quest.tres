[resource]
script = ExtResource("1_b7urw")
title = "Phantom Toy"
description = "PhantomToy relata la historia de un niño que encuentra un antiguo peluche de retazos en una feria abandonada. A simple vista parece un juguete tierno y desgastado por el tiempo, pero pronto el protagonista descubre que está poseído por el espíritu fragmentado de un niño que desapareció misteriosamente años atrás dentro de la feria."
authors = Array[String](["Fabian Delgado", "Raphael Caballero", "Samantha Valencia", "Luis Cruz"])
affiliation = "UTP"
first_scene = "uid://c3cxjolceg82f"
threads_to_collect = 2
sprite_frames = SubResource("SpriteFrames_xufag")
animation_name = &"osito"
metadata/_custom_type_script = "uid://dts1hwdy3phin"
