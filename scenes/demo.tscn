[sub_resource type="GDScript" id="GDScript_vgxrn"]
script/source = "extends CharacterBody2D

@onready var path_walk_behavior = $PathWalkBehavior
@onready var follow_walk_behavior = $FollowWalkBehavior

@onready var player_awareness: TextureProgressBar = $PlayerAwareness
@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D
@onready var character_sprite_behavior: CharacterSpriteBehavior = $AnimatedSprite2D/CharacterSpriteBehavior


## The state of this guard.
enum State {
		## The guard walks along a path.
		PATROLLING,
		## The guard is chasing the player.
		CHASING,
		## The guard captured the player.
		ALERTED,
}

var state := State.PATROLLING:
		set = _set_state


func _set_state(new_state: State) -> void:
	state = new_state

	if not is_node_ready():
		return

	match state:
		State.PATROLLING:
			path_walk_behavior.process_mode = Node.PROCESS_MODE_INHERIT
			follow_walk_behavior.process_mode = Node.PROCESS_MODE_DISABLED
		State.CHASING:
			path_walk_behavior.process_mode = Node.PROCESS_MODE_DISABLED
			follow_walk_behavior.process_mode = Node.PROCESS_MODE_INHERIT
		State.ALERTED:
			path_walk_behavior.process_mode = Node.PROCESS_MODE_DISABLED
			follow_walk_behavior.process_mode = Node.PROCESS_MODE_DISABLED
			character_sprite_behavior.process_mode = Node.PROCESS_MODE_DISABLED
			animated_sprite_2d.play(&\"alerted\")
			player_awareness.ratio = 1.0
			player_awareness.tint_progress = Color.RED


func _on_detection_area_body_entered(_body: Node2D) -> void:
	if state == State.ALERTED:
		return
	state = State.CHASING


func _on_detection_area_body_exited(_body: Node2D) -> void:
	if state == State.ALERTED:
		return
	state = State.PATROLLING


func _physics_process(delta: float) -> void:
	match state:
		State.PATROLLING:
			player_awareness.value = move_toward(player_awareness.value, 0.0, delta)
		State.CHASING:
			player_awareness.value = move_toward(player_awareness.value, player_awareness.max_value, delta)
			if player_awareness.value >= player_awareness.max_value:
				state = State.ALERTED
	player_awareness.visible = player_awareness.value > 0
"

