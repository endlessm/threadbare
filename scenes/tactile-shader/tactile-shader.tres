code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool enabled = true;
uniform float zoom = 2.0;
uniform sampler2D screen_tex_frg_2 : hint_screen_texture;


// CircleShape
#include \"res://scenes/tactile-shader/generateCircle.gdshaderinc\"

void fragment() {
// BooleanParameter:11
	bool n_out11p0 = enabled;


	vec3 n_out5p0;
	float n_out5p1;
// CircleShape:5
	vec3 n_in5p1 = vec3(0.50000, 0.50000, 0.00000);
	vec3 n_in5p2 = vec3(1.00000, 1.00000, 0.00000);
	float n_in5p3 = -0.50000;
	float n_in5p4 = 0.50000;
	float n_in5p5 = 0.20000;
	vec3 n_in5p6 = vec3(1.00000, 1.00000, 1.00000);
	float n_in5p7 = 1.00000;
	{
		n_out5p0 = n_in5p6;
		n_out5p1 = _generateCircleFunc(UV.xy, n_in5p1.xy, n_in5p2.xy, n_in5p3, n_in5p4, n_in5p5).a * n_in5p7;
	}


// FloatParameter:8
	float n_out8p0 = zoom;


// FloatOp:9
	float n_in9p0 = -0.05000;
	float n_out9p0 = n_in9p0 * n_out8p0;


// VectorCompose:10
	float n_in10p0 = 0.00000;
	vec2 n_out10p0 = vec2(n_in10p0, n_out9p0);


// Input:3
	vec2 n_out3p0 = SCREEN_UV;


// MultiplyAdd:4
	vec2 n_out4p0 = (vec2(n_out5p1) * n_out10p0) + n_out3p0;


	vec2 n_out12p0;
// Switch:12
	n_out12p0 = mix(n_out3p0, n_out4p0, float(n_out11p0));


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(screen_tex_frg_2, n_out12p0);


// Output:0
	COLOR.rgb = vec3(n_out2p0.xyz);


}
"
