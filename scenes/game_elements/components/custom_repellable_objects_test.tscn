[node name="RepellableBox" parent="OnTheGround" unique_id=1805651676 node_paths=PackedStringArray("constrain_layer") instance=ExtResource("8_uhkpe")]
editor_description = "A repellable box that moves in a fixed grid.

This is an AnimatableBody2D so it can move along the tiles of a TileMapLayer (using a Tweener for animating the position).

It needs a TileMapLayer and it is constrained to the painted tiles.

 Since it is animated, it doesn't collide with other instances of itself! For making a puzzle like a Sokoban, the logic must be managed in some other way."
position = Vector2(416, 608)
constrain_layer = NodePath("../../TileMapLayers/Paths")
metadata/_edit_group_ = true

