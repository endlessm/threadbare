theme_override_font_sizes/font_size = 28
theme_override_colors/bookmark_color = Color(1, 0.333333, 0.333333, 1)
text = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
~ start
These buttons aren't reachable...
Do you want some extra needles?
- Yes => help_accepted
- No => help_denied

~ help_accepted
do ExtraNeedles.add_extra_needles()
Bye!
do GameState.global.clear_help()
=> END

~ help_denied
OK, bye!
=> END
"
scroll_smooth = true
syntax_highlighter = SubResource("SyntaxHighlighter_mpdoc")

