# Godot 4+ specific ignores
.godot/
/android/

# Build & export artifacts
build/

# macOS system files
.AppleDouble
.DS_Store
._*
__MACOSX

# Archive formats
*.zip
*.rar

# Gettext generated files
*/locale/*.mo


# Temporary files, created in particular by Godot on Windows if you modify and
# save a scene in the editor while it is in use by the running game.
*.tmp

*~

# LibreOffice lock files, created while editing credits CSV files
.~lock.*#

# Godot Backstitch addon, bundled editor build, and config/state files, from
# https://github.com/inkandswitch/backstitch-launcher/blob/main/.gitignore.template
/addons/backstitch/
/godot_editor/
.backstitch_version
/.backstitch/
backstitch.cfg

# Raw third-party asset pack (CC0). Kept locally; only the assets actually used
# are copied into assets/ and committed. Keeps the repo from bloating with ~109MB
# of unused sprites/audio. See its LICENSE.txt before redistributing.
docs-grupo/Ninja Adventure - Asset Pack/
