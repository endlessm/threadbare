script/source = "extends CharacterBody2D

@export var walk_speed: float = 200.0

func _physics_process(delta):
	var direction = Input.get_vector(\"ui_left\", \"ui_right\", \"ui_up\", \"ui_down\")
	velocity = direction * walk_speed
	move_and_slide()
"

