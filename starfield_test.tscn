[sub_resource type="Shader" id="Shader_bmckr"]
code = "shader_type canvas_item;

uniform vec2 resolution = vec2(600.0, 400.0);
uniform sampler2D noise_texture: filter_nearest, repeat_enable;
uniform float density: hint_range(1.0, 100.0, 0.1) = 20.0;

uniform vec2 camera_pos;

// COLOR is input too!
void fragment() {
	vec2 uv = UV;
	uv.x *= resolution.x / resolution.y;
	float stars = 0.0;
	stars += step(0.2, pow(texture(noise_texture, uv + camera_pos / resolution).r, density));
	// TODO blend with source texture
	COLOR = vec4(vec3(stars), 1.0) + COLOR;
}
"

[sub_resource type="FastNoiseLite" id="FastNoiseLite_ebh07"]
noise_type = 0
frequency = 0.35

[sub_resource type="NoiseTexture2D" id="NoiseTexture2D_bmckr"]
noise = SubResource("FastNoiseLite_ebh07")

[sub_resource type="ShaderMaterial" id="ShaderMaterial_4wj8d"]
shader = SubResource("Shader_bmckr")
shader_parameter/resolution = Vector2(600, 400)
shader_parameter/noise_texture = SubResource("NoiseTexture2D_bmckr")
shader_parameter/density = 20.0
shader_parameter/camera_pos = Vector2(0, 0)

[sub_resource type="GDScript" id="GDScript_bmckr"]
script/source = "# SPDX-FileCopyrightText: The Threadbare Authors
# SPDX-License-Identifier: MPL-2.0
extends TileMapLayer

@export var camera: Camera2D

func _process(_delta: float) -> void:
	(material as ShaderMaterial).set_shader_parameter(\"camera_pos\", camera.position)
"

